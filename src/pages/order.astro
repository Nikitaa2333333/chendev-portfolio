---
import Layout from '@/layouts/Layout.astro';
import { typo } from '@/lib/typo';

const withBase = (p: string) => import.meta.env.BASE_URL.replace(/\/$/, '') + p;
---

<Layout
  title="Заказать сайт — Никита Чендев"
  description="Оставьте заявку: имя, телефон или ссылка на соцсеть. Отвечу в течение дня и бесплатно сделаю первую концепцию вашего сайта."
  noindex={true}
>
  <main class="order">
    <a class="order__back" href={withBase('/')}>{typo('← на главную')}</a>

    <div class="order__inner">
      {/* Форма и экран «спасибо» — два состояния одного блока: отправка идёт
          через fetch, страница не перезагружается. */}
      <div class="order__form-wrap" data-form-wrap>
        <h1 class="order__title">{typo('Заказать сайт')}</h1>
        <p class="order__lead">
          {typo('Отвечу в течение дня и бесплатно сделаю первую концепцию вашего сайта.')}
        </p>
        <form class="form" action={withBase('/send.php')} method="post" data-form novalidate>
          <label class="field">
            <span class="field__label">{typo('Как вас зовут')}</span>
            <input class="field__input" type="text" name="name" autocomplete="name" />
            <span class="field__error" data-error="name"></span>
          </label>

          <label class="field">
            <span class="field__label">{typo('Телефон')}</span>
            <input
              class="field__input"
              type="tel"
              name="phone"
              inputmode="tel"
              autocomplete="tel"
              placeholder="+7 900 000 00 00"
              data-phone
            />
            <span class="field__error" data-error="phone"></span>
          </label>

          <label class="field">
            <span class="field__label">{typo('Ссылка на любую соцсеть')}</span>
            <input
              class="field__input"
              type="text"
              name="social"
              autocomplete="url"
              placeholder="@username, t.me/…, vk.com/…"
            />
            <span class="field__error" data-error="social"></span>
          </label>

          <label class="field">
            <span class="field__label">{typo('Чем занимаетесь')}</span>
            <input
              class="field__input"
              type="text"
              name="about"
              autocomplete="organization"
              placeholder={typo('Кофейня, стоматология, доставка цветов…')}
            />
            <span class="field__error" data-error="about"></span>
          </label>

          {/* Honeypot: человек его не видит и не заполнит — только спам-бот. */}
          <div class="hp" aria-hidden="true">
            <label>Компания<input type="text" name="company" tabindex="-1" autocomplete="off" /></label>
          </div>

          <button class="form__submit" type="submit" data-submit>{typo('Отправить заявку')}</button>
          {/* Пометка живёт ПОД кнопкой — не задерживает на входе в форму,
              а объясняет уже после того, как человек увидел поля. */}
          <p class="order__note">
            {typo('Все поля необязательные — заполняйте как удобно. Оставьте телефон или ссылку на соцсеть, чтобы я мог ответить.')}
          </p>
          <p class="form__note" data-form-error hidden></p>
        </form>
      </div>

      <div class="done" data-done hidden>
        <h1 class="order__title">{typo('Заявка отправлена')}</h1>
        <p class="order__lead">{typo('Спасибо! Свяжусь с вами в течение дня.')}</p>
        <a class="done__link" href={withBase('/')}>{typo('Вернуться на главную')}</a>
      </div>
    </div>
  </main>
</Layout>

<style>
  /* Страница-форма на сплошном синем: экран целиком в акценте, текст белый.
     Скруглений-пилюль нет — прямоугольники с --radius-card (4px), как плитки. */
  .order {
    min-height: 100svh;
    padding: 96px 15px var(--section-pad-y);
    background: var(--color-accent);
  }
  .order__inner {
    max-width: var(--measure);
    margin: 0 auto;
  }
  .order__back {
    position: fixed;
    top: 14px;
    left: 15px;
    z-index: 50;
    font-size: var(--text-h3);
    font-weight: var(--fw-black);
    line-height: 1;
    color: var(--color-paper-white);
    text-decoration: none;
  }
  .order__title {
    font-size: var(--text-h1);
    font-weight: var(--fw-black);
    line-height: 1.05;
    color: var(--color-paper-white);
  }
  /* «Единый набор»: лид отбит от заголовка на свой межабзацный интервал. */
  .order__lead {
    margin-top: calc(var(--text-lead) * 0.8);
    font-size: var(--text-lead);
    color: var(--color-paper-white);
  }
  /* Пометка под кнопкой: отбита своим межстрочным интервалом, не «висит». */
  .order__note {
    margin-top: calc(var(--text-body) * 0.8);
    font-size: var(--text-body);
    color: var(--color-paper-white);
  }

  /* Поля стоят плотно: это одна анкета, а не набор отдельных блоков. */
  .form {
    margin-top: var(--spacing-32);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-12);
  }
  /* Кнопку от последнего поля отбиваем сильнее — она другой шаг сценария. */
  .form__submit { margin-top: var(--spacing-12); }
  .field { display: block; }
  .field__label {
    display: block;
    margin-bottom: 8px;
    font-size: var(--text-body);
    font-weight: var(--fw-medium);
    color: var(--color-paper-white);
  }
  /* Поле — белый прямоугольник на синем: внутри белого текст чёрный (правило 1). */
  .field__input {
    width: 100%;
    padding: 14px 16px;
    font-family: var(--font-sans);
    font-size: var(--text-lead);
    font-weight: var(--fw-medium);
    color: var(--color-ink-black);
    background: var(--color-paper-white);
    border: var(--border-w) solid var(--color-paper-white);
    border-radius: var(--radius-card);
  }
  .field__input:focus {
    outline: 2px solid var(--color-paper-white);
    outline-offset: 3px;
  }
  /* Плейсхолдер — зафиксированное исключение из правила контраста:
     иначе он неотличим от уже введённого текста. */
  .field__input::placeholder { color: #6b7280; }
  /* Ошибочное поле: тёплая рамка + такая же подпись под ним. На синем это
     единственный цвет, который читается как «внимание» и не спорит с белым. */
  .field__input[aria-invalid='true'] { border-color: var(--color-cream-wash); }

  .field__error {
    display: none;
    margin-top: 6px;
    font-size: var(--text-caption);
    font-weight: var(--fw-black);
    color: var(--color-cream-wash);
  }
  .field__error[data-shown] { display: block; }

  /* Кнопка — чёрный прямоугольник: на синем это самый контрастный тон,
     сильнее белого (белым здесь набраны подписи и поля, кнопка не должна
     теряться среди них). Радиус тот же, что у полей. */
  .form__submit {
    align-self: flex-start;
    padding: 16px 32px;
    font-family: var(--font-sans);
    font-size: var(--text-lead);
    font-weight: var(--fw-medium);
    color: var(--color-paper-white);
    background: var(--color-ink-black);
    border: var(--border-w) solid var(--color-ink-black);
    border-radius: var(--radius-card);
    cursor: pointer;
  }
  .form__submit:hover { background: var(--color-accent-900); border-color: var(--color-accent-900); }
  .form__submit[disabled] { cursor: progress; }

  .form__note {
    font-size: var(--text-body);
    font-weight: var(--fw-black);
    color: var(--color-cream-wash);
  }
  .form__note :global(a) { color: var(--color-cream-wash); }

  /* Honeypot: убран из потока и от скринридеров, но заполняем-доступен ботам. */
  .hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .done__link {
    display: inline-block;
    margin-top: var(--spacing-24);
    font-size: var(--text-lead);
    font-weight: var(--fw-medium);
    color: var(--color-paper-white);
    text-decoration-color: var(--color-sky-tint);
  }

  @media (max-width: 719px) {
    .order { padding-top: 72px; }
    .form__submit { align-self: stretch; text-align: center; }
  }
</style>

<script>
  // Отправка без перезагрузки. Без JS форма работает как обычный POST на send.php.
  function initOrderForm() {
    const form = document.querySelector<HTMLFormElement>('[data-form]');
    if (!form) return;

    const wrap = document.querySelector<HTMLElement>('[data-form-wrap]');
    const done = document.querySelector<HTMLElement>('[data-done]');
    const submit = form.querySelector<HTMLButtonElement>('[data-submit]');
    const note = form.querySelector<HTMLElement>('[data-form-error]');

    // Российский номер: 10 цифр после кода страны. Принимаем +7…, 8…, 7…
    // и просто 10 цифр — человек не должен угадывать формат.
    const normalizeRu = (raw: string): string | null => {
      let d = raw.replace(/\D+/g, '');
      if (d.length === 11 && (d[0] === '8' || d[0] === '7')) d = d.slice(1);
      if (d.length !== 10) return null;
      // Мобильные и городские РФ начинаются с 3/4/8/9 — 0,1,2 отсекаем как опечатку.
      if (!/^[3489]/.test(d)) return null;
      return '+7' + d;
    };

    const clearErrors = () => {
      form.querySelectorAll<HTMLElement>('[data-error]').forEach((el) => {
        el.textContent = '';
        el.removeAttribute('data-shown');
      });
      form.querySelectorAll<HTMLInputElement>('input').forEach((i) => i.removeAttribute('aria-invalid'));
      if (note) { note.hidden = true; note.textContent = ''; }
    };

    const showErrors = (errors: Record<string, string>) => {
      for (const [field, message] of Object.entries(errors)) {
        const el = form.querySelector<HTMLElement>(`[data-error="${field}"]`);
        const input = form.querySelector<HTMLInputElement>(`[name="${field}"]`);
        if (el) { el.textContent = message; el.setAttribute('data-shown', ''); }
        if (input) input.setAttribute('aria-invalid', 'true');
      }
      form.querySelector<HTMLInputElement>('[aria-invalid="true"]')?.focus();
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      clearErrors();

      const data = new FormData(form);
      const name = String(data.get('name') ?? '').trim();
      const phone = String(data.get('phone') ?? '').trim();
      const social = String(data.get('social') ?? '').trim();
      const about = String(data.get('about') ?? '').trim();
      const local: Record<string, string> = {};

      // Имя — буквы, пробел, дефис, апостроф. Цифры и «!!!???» отсекаем:
      // это либо опечатка, либо мусор от бота.
      if (name && !/^[a-zA-Zа-яА-ЯёЁ][a-zA-Zа-яА-ЯёЁ\s'-]*$/.test(name)) {
        local.name = 'Только буквы — без цифр и символов';
      }

      // Поля по отдельности необязательны, но ответить как-то надо:
      // просим либо телефон, либо соцсеть.
      if (!phone && !social) {
        local.phone = 'Оставьте телефон или ссылку на соцсеть — иначе я не смогу ответить';
      } else if (phone) {
        const normalized = normalizeRu(phone);
        if (!normalized) local.phone = 'Похоже, номер неполный. Российский формат: +7 900 000 00 00';
        else data.set('phone', normalized);
      }

      // Соцсеть должна быть похожа на адрес или ник: набор букв/цифр от 3 знаков.
      // Иначе «!!!» прошло бы как контакт, а связаться было бы нельзя.
      if (social && !/[a-zA-Zа-яА-Я0-9]{3}/.test(social)) {
        local.social = 'Похоже на опечатку. Например: @username или t.me/username';
      }

      // Род занятий — просто текст, но не сплошные символы.
      if (about && !/[a-zA-Zа-яА-ЯёЁ0-9]{2}/.test(about)) {
        local.about = 'Пара слов о деле — например, «кофейня»';
      }

      if (Object.keys(local).length) { showErrors(local); return; }

      if (submit) { submit.disabled = true; submit.textContent = 'Отправляю…'; }

      try {
        const res = await fetch(form.action, { method: 'POST', body: data });
        const json = await res.json().catch(() => null);

        if (res.ok && json?.ok) {
          if (wrap) wrap.hidden = true;
          if (done) { done.hidden = false; done.scrollIntoView({ block: 'center' }); }
          return;
        }
        if (res.status === 422 && json?.errors) { showErrors(json.errors); return; }
        throw new Error('send failed');
      } catch {
        // Тупик недопустим: даём живые контакты прямо в сообщении об ошибке.
        if (note) {
          note.innerHTML =
            'Не получилось отправить. Напишите в <a href="https://t.me/chendev1">Telegram</a> ' +
            'или позвоните: <a href="tel:+79531216477">+7 953 121 64 77</a>';
          note.hidden = false;
        }
      } finally {
        if (submit) { submit.disabled = false; submit.textContent = 'Отправить заявку'; }
      }
    });
  }

  initOrderForm();
  document.addEventListener('astro:page-load', initOrderForm);
</script>

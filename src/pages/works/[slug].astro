---
import Layout from '@/layouts/Layout.astro';
import Footer from '@/components/Footer.astro';
import { works } from '@/data/works';
import { typo } from '@/lib/typo';

export function getStaticPaths() {
  return works.map((w) => ({ params: { slug: w.slug }, props: { work: w } }));
}

const { work } = Astro.props;

// Чистый домен для подписи ссылки (https://noble-farm.ru/ → noble-farm.ru)
const siteLabel = work.siteUrl?.replace(/^https?:\/\//, '').replace(/\/$/, '');
const idx = works.findIndex((w) => w.slug === work.slug);
const prev = works[(idx - 1 + works.length) % works.length];
const next = works[(idx + 1) % works.length];

// База под GitHub Pages в подпапке: пути в works.ts начинаются с '/'.
const withBase = (p: string) => import.meta.env.BASE_URL.replace(/\/$/, '') + p;

// Контакты автора (CTA). Telegram пока заглушка — заменим на реальную ссылку.
const contacts = [
  { label: 'Telegram', href: '#' },
  { label: 'chendev2003@gmail.com', href: 'mailto:chendev2003@gmail.com' },
  { label: '+7 953 121 74 77', href: 'tel:+79531217477' },
];

// Единый список контент-секций (обзор + блоки), рендер по порядку.
type Section =
  | { kind: 'overview' }
  | { kind: 'block'; block: NonNullable<typeof work.blocks>[number] };
const sections: Section[] = [
  ...(work.overview ? [{ kind: 'overview' } as Section] : []),
  ...((work.blocks ?? []).map((block) => ({ kind: 'block', block }) as Section)),
];
---

<Layout title={`${work.title} — кейс`}>
  <main class="case" style={`--surface:${work.surface}`}>
    {/* ── Hero: видео/картинка на весь экран ── */}
    <section class="hero" style={`--surface:${work.surface}`}>
      {work.video ? (
        <>
          {work.poster && (
            <img class="hero__media hero__poster" src={withBase(work.poster)} alt={work.title} />
          )}
          <video
            class="hero__media hero__video"
            data-hero-video
            muted
            loop
            playsinline
            webkit-playsinline
            preload="auto"
            autoplay
            poster={work.poster ? withBase(work.poster) : undefined}
          >
            <source src={withBase(work.video)} type="video/mp4" />
          </video>
        </>
      ) : work.image ? (
        <img class="hero__media" src={withBase(work.image)} alt={work.title} />
      ) : work.variant === 'glow' ? (
        <div class="hero__glow" aria-hidden="true">
          <div class="glow__ring"></div>
          <div class="glow__blob"></div>
        </div>
      ) : null}

      <div class="hero__grad"></div>

      <a class="hero__back" href={withBase('/#works')}>{typo('← к работам')}</a>

      <div class="hero__cap">
        <h1 class="hero__title">{typo(work.title)}</h1>
        <p class="hero__tags mono">{work.tags.join(' · ')} · {work.year}</p>
      </div>
    </section>

    {/* ── Обзор + контент-блоки: единый поток полос, фон чередуется белый ↔ цвет ── */}
    {sections.map((s) => (
      <section class:list={['band', 'sec--wrap', { 'band--tint': s.kind === 'overview' }]}>
        {s.kind === 'overview' ? (
          <div class="overview">
            {work.overview!.split('\n').filter(Boolean).map((par) => (
              <p class="lead">{typo(par)}</p>
            ))}
            {work.siteUrl && (
              <div class="sitelink-wrap">
                <span class="sitelink__badge">Посмотреть сайт</span>
                <a class="sitelink" href={work.siteUrl} target="_blank" rel="noopener noreferrer">{siteLabel}</a>
              </div>
            )}
          </div>
        ) : s.block.type === 'text' ? (
          <div class="text-block">
            {s.block.heading && <h2 class="h2">{typo(s.block.heading)}</h2>}
            <p class="body">{typo(s.block.body)}</p>
          </div>
        ) : s.block.type === 'quote' ? (
          <div>
            <blockquote class="quote">{typo(s.block.text)}</blockquote>
            {s.block.author && <p class="quote__author mono">{typo(s.block.author)}</p>}
          </div>
        ) : (
          <figure class="figure">
            <div class="figure__media">
              {s.block.src ? (
                <img src={withBase(s.block.src)} alt={s.block.alt ?? s.block.caption ?? work.title} loading="lazy" />
              ) : (
                <span class="figure__ph mono">[ скрин — заглушка ]</span>
              )}
            </div>
            {s.block.caption && <figcaption class="figure__cap mono">{typo(s.block.caption)}</figcaption>}
          </figure>
        )}
      </section>
    ))}

    {/* ── CTA: написать автору ── */}
    <section class="cta">
      <div class="cta__inner sec--wrap">
        <h2 class="cta__title">{typo('Хотите такой же сайт?')}</h2>
        <p class="cta__lead">{typo('Напишите Никите — обсудим проект и соберём сайт, который работает на вас.')}</p>
        <div class="cta__links">
          {contacts.map((c) => (
            <a class="cta__link" href={c.href}>{c.label}</a>
          ))}
        </div>
      </div>
    </section>

    {/* ── Навигация по кейсам ── */}
    <nav class="case-nav sec--wrap" aria-label="Другие работы">
      <a class="case-nav__item" href={withBase(`/works/${prev.slug}`)}>
        <span class="mono">← предыдущая</span>
        <span class="case-nav__title">{typo(prev.title)}</span>
      </a>
      <a class="case-nav__item case-nav__item--next" href={withBase(`/works/${next.slug}`)}>
        <span class="mono">следующая →</span>
        <span class="case-nav__title">{typo(next.title)}</span>
      </a>
    </nav>
  </main>

  <Footer />
</Layout>

<style>
  /* ============================================================
     Страница кейса. Полноширинная, боковые поля 15px (как везде).
     Hero — единственное full-bleed-исключение (от края до края).
     ============================================================ */
  .sec--wrap { padding-left: 15px; padding-right: 15px; }

  /* ---- Hero на весь экран ---- */
  .hero {
    position: relative;
    height: 100svh;
    min-height: 480px;
    background: var(--surface);
    overflow: hidden;
  }
  .hero__media {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
  }
  .hero__poster { z-index: 0; }   /* статичный кадр — виден сразу, пока грузится видео */
  .hero__video { z-index: 1; }    /* видео поверх; прячется, если автоплей заблокирован */
  .hero__video[hidden] { display: none; }
  /* Glow-hero: продолжение анимации с плитки галереи (синее свечение на CSS).
     Крупнее — на весь экран кейса. Разрешённое исключение из «без прозрачностей». */
  .hero__glow { position: absolute; inset: 0; background: #0a0b0d; overflow: hidden; }
  .hero__glow .glow__ring {
    position: absolute; top: 50%; left: 50%;
    width: min(120vh, 92vw); aspect-ratio: 1; border-radius: 50%;
    transform: translate(-50%, -50%);
    filter: blur(60px) brightness(1.7) saturate(1.3);
    background: radial-gradient(circle,
      transparent 34%,
      rgba(96,165,250,1) 43%,
      rgba(37,99,235,1) 50%,
      rgba(37,99,235,0.75) 57%,
      transparent 66%);
    animation: hero-glow-pulse 4s ease-in-out infinite;
  }
  .hero__glow .glow__blob {
    position: absolute; top: 50%; left: 50%;
    width: min(70vh, 60vw); aspect-ratio: 1; border-radius: 50%;
    transform: translate(-50%, -50%);
    filter: blur(70px) brightness(1.6) saturate(1.3);
    background: radial-gradient(circle,
      rgba(147,197,253,1) 0%,
      rgba(59,130,246,1) 42%,
      transparent 70%);
    animation: hero-glow-orbit 5s linear infinite;
  }
  @keyframes hero-glow-pulse {
    0%, 100% { opacity: .9; transform: translate(-50%, -50%) scale(.99); }
    50%      { opacity: 1;  transform: translate(-50%, -50%) scale(1.08); }
  }
  @keyframes hero-glow-orbit {
    0%   { transform: translate(-50%, -50%) translate(0, -12%); }
    25%  { transform: translate(-50%, -50%) translate(10%, 0); }
    50%  { transform: translate(-50%, -50%) translate(0, 12%); }
    75%  { transform: translate(-50%, -50%) translate(-10%, 0); }
    100% { transform: translate(-50%, -50%) translate(0, -12%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__glow .glow__ring, .hero__glow .glow__blob { animation: none; }
  }
  /* Градиент снизу — В ЦВЕТ КЕЙСА (как на главной у плиток): видео утопает
     в свой бренд-цвет, белое название читается. Solid surface у самого низа.
     (Разрешённое исключение из «без прозрачностей» — ради читабельности.) */
  .hero__grad {
    position: absolute; inset: 0;
    z-index: 2;   /* поверх видео (video z-index:1), иначе градиент перекрывается */
    background: linear-gradient(
      to top,
      var(--surface) 0%,
      color-mix(in srgb, var(--surface) 80%, transparent) 25%,
      transparent 60%
    );
  }
  /* Кнопка «← к работам» — ЗАФИКСИРОВАНА в шапке (fixed), едет с прокруткой.
     Крупная, Inter 900. mix-blend-mode: difference → инвертирует фон под собой:
     над тёмным видео белая, над белой полосой чёрная, над синей — инверт.
     Текст «проходит» сквозь контент и всегда остаётся контрастным. */
  .hero__back {
    position: fixed; top: 14px; left: 15px;
    z-index: 50;
    display: inline-block;
    font-size: var(--text-h3);
    font-weight: var(--fw-black);
    line-height: 1;
    color: var(--color-paper-white);
    text-decoration: none;
    mix-blend-mode: difference;
    will-change: transform;
  }
  @media (prefers-reduced-motion: reduce) { .hero__back { will-change: auto; } }
  .hero__cap {
    position: absolute; left: 15px; right: 15px; bottom: 40px;
    z-index: 2;
  }
  .hero__title {
    color: var(--color-paper-white);
    font-size: var(--text-h1);
    line-height: var(--lh-h1);
    font-weight: var(--fw-black);
    margin: 0 0 var(--spacing-12);
    max-width: 18ch;
  }
  .hero__tags { color: var(--color-paper-white); }

  /* ---- Секции контента (обзор + блоки) ---- */
  /* ВАЖНО: вертикальные паддинги только -top/-bottom — боковые 15px из .sec--wrap. */
  .band { padding-top: var(--spacing-48); padding-bottom: var(--spacing-48); }
  /* Обзор — полоса в цвет проекта, текст и ссылка белые (на цвете → белый).
     Подтянут вплотную к hero (меньше top): hero + описание = единый блок. */
  .band--tint { background: var(--surface); color: var(--color-paper-white); padding-top: var(--spacing-24); }
  .band--tint .lead { color: var(--color-paper-white); }
  /* На синей полосе ссылка белая (подчёркивание берёт currentColor → тоже белое). */
  .band--tint .sitelink,
  .band--tint .sitelink:hover { color: var(--color-paper-white); }
  .lead {
    font-size: var(--text-lead);
    line-height: var(--lh-lead);
    color: var(--color-ink-black);
    max-width: 62ch;
    margin: 0;
  }
  .h2 {
    font-size: var(--text-h2);
    line-height: var(--lh-h2);
    font-weight: var(--fw-black);
    color: var(--color-ink-black);
    margin: 0 0 var(--spacing-16);
  }
  .body {
    font-size: var(--text-body);
    line-height: var(--lh-body);
    color: var(--color-ink-black);
    max-width: 62ch;
    margin: 0;
  }
  /* container-type: контейнер для cqw — мобильная ссылка тянется от РЕАЛЬНОЙ
     ширины блока (без скроллбара, в отличие от 100vw, который его включает). */
  .overview { container-type: inline-size; }
  /* Абзацы обзора — интервал между ними */
  .overview .lead { margin-bottom: var(--spacing-16); }
  .overview .lead:last-of-type { margin-bottom: 0; }

  /* Блок ссылки на живой сайт: сверху мелкая бирка «Посмотреть сайт»,
     под ней — домен крупной чёрной ссылкой, подчёркнут как гиперссылка. */
  .sitelink-wrap { margin-top: var(--spacing-24); }
  .sitelink__badge {
    display: block;
    font-size: var(--text-caption);
    font-weight: var(--fw-medium);
    color: var(--color-ink-black);
    margin-bottom: var(--spacing-4);
  }
  .band--tint .sitelink__badge { color: var(--color-paper-white); }
  .sitelink {
    display: inline-block;
    max-width: 100%;
    overflow-wrap: anywhere;
    font-size: var(--text-h3);
    font-weight: var(--fw-black);
    color: var(--color-ink-black);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
  }

  /* ---- Картинка / плейсхолдер во всю ширину ---- */
  .figure { margin: 0; }
  .figure__media {
    border-radius: var(--radius-card);
    overflow: hidden;
    background: var(--surface);
    aspect-ratio: 16 / 9;
    display: flex; align-items: center; justify-content: center;
  }
  .figure__media img { width: 100%; height: 100%; object-fit: cover; }
  .figure__ph { color: var(--color-paper-white); }
  .figure__cap {
    margin: var(--spacing-8) 0 0;
    color: var(--color-ink-black);
  }

  /* ---- Цитата ---- */
  .quote {
    font-size: var(--text-h3);
    line-height: var(--lh-h3);
    font-weight: var(--fw-black);
    color: var(--color-ink-black);
    margin: 0; max-width: 50ch;
  }
  .quote__author { margin: var(--spacing-12) 0 0; }

  /* ---- CTA: синяя секция, белый текст ---- */
  .cta {
    background: var(--color-accent);
    margin-top: var(--spacing-48);
  }
  .cta__inner { padding-top: var(--spacing-80); padding-bottom: var(--spacing-80); }
  .cta__title {
    font-size: var(--text-h1);
    line-height: var(--lh-h1);
    font-weight: var(--fw-black);
    color: var(--color-paper-white);
    margin: 0 0 var(--spacing-16);
    max-width: 16ch;
  }
  .cta__lead {
    font-size: var(--text-lead);
    line-height: var(--lh-lead);
    color: var(--color-paper-white);
    max-width: 48ch;
    margin: 0 0 var(--spacing-32);
  }
  .cta__links { display: flex; flex-wrap: wrap; gap: var(--spacing-12); }
  .cta__link {
    display: inline-flex; align-items: center;
    background: var(--color-paper-white);
    color: var(--color-ink-black);
    font-weight: var(--fw-medium);
    text-decoration: none;
    border-radius: var(--radius-pill);
    padding: 12px 24px;
  }
  .cta__link:hover { background: var(--color-paper-white); transform: translateY(-1px); }

  /* ---- Навигация по кейсам ---- */
  .case-nav {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-8);
    padding-top: var(--spacing-48);
    padding-bottom: var(--spacing-96);
  }
  @media (min-width: 720px) { .case-nav { grid-template-columns: 1fr 1fr; } }
  .case-nav__item {
    display: flex; flex-direction: column; gap: var(--spacing-4);
    border: var(--border-w) var(--border-style) var(--border-color);
    border-radius: var(--radius-card);
    padding: var(--spacing-24);
    text-decoration: none;
    color: var(--color-ink-black);
    background: var(--color-paper-white);
  }
  .case-nav__item--next { text-align: right; align-items: flex-end; }
  .case-nav__item:hover { background: var(--color-faint-slate); }
  .case-nav__title { font-size: var(--text-h3); font-weight: var(--fw-black); }

  /* ---- Адаптив ---- */
  @media (max-width: 767px) {
    .hero__title { font-size: 40px; }
    .h2 { font-size: var(--text-h3); }
    .cta__title { font-size: var(--text-h2); }
    /* Ссылка на сайт — крупная на мобилке, домен в одну строку, почти от края
       до края. cqw = 1% ширины .overview (без скроллбара) → не переполняется. */
    .sitelink-wrap { margin-top: var(--spacing-32); }
    .sitelink {
      white-space: nowrap;
      font-size: calc(100cqw / 7.9);
    }
  }
</style>

<script>
  // Hero-видео: автоплей в зоне видимости, пауза вне (экономит батарею).
  // Если браузер блокирует автоплей (iOS Low Power и т.п.) → прячем видео,
  // под ним остаётся статичный постер (без мёртвой системной кнопки play).
  // prefers-reduced-motion → тоже остаётся постер.
  function initHeroVideo() {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const video = document.querySelector<HTMLVideoElement>('video[data-hero-video]');
    if (!video) return;
    const fallbackToPoster = () => { video.hidden = true; video.pause(); };
    if (reduce) { fallbackToPoster(); return; }

    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            const p = video.play();
            if (p && typeof p.catch === 'function') p.catch(fallbackToPoster);
          } else {
            video.pause();
          }
        }
      },
      { threshold: 0.25 }
    );
    io.observe(video);
  }
  initHeroVideo();
  document.addEventListener('astro:page-load', initHeroVideo);
</script>

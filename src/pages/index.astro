---
import Layout from '@/layouts/Layout.astro';
import Hero from '@/components/Hero.astro';
import Works from '@/components/Works.astro';
import Contact from '@/components/Contact.astro';
// About / Process / Testimonials / Footer сняты: заглушки и лишние блоки
// на время стройки. Компоненты живут в src/components — вернём по мере готовности.

// JSON-LD: кто автор и что это за сайт — машиночитаемо для Яндекса и Google.
const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': new URL(import.meta.env.BASE_URL, Astro.site).href + '#person',
      name: 'Никита Чендев',
      jobTitle: 'Дизайнер и разработчик сайтов',
      email: 'mailto:chendev.nik@gmail.com',
      telephone: '+7 953 121 64 77',
      url: new URL(import.meta.env.BASE_URL, Astro.site).href,
      sameAs: ['https://t.me/chendev1'],
    },
    {
      '@type': 'WebSite',
      name: 'Никита Чендев — дизайн и разработка сайтов',
      url: new URL(import.meta.env.BASE_URL, Astro.site).href,
      inLanguage: 'ru',
      author: { '@id': new URL(import.meta.env.BASE_URL, Astro.site).href + '#person' },
    },
  ],
};
---

<Layout
  title="Никита Чендев — дизайн и разработка сайтов"
  description="Делаю сайты с нуля, без шаблона и конструктора: уникальный дизайн за две недели и бесплатная гарантия один год. Портфолио — 13 живых проектов."
  schema={schema}
>
  <main>
    <Hero />
    <Works />
    <Contact />
  </main>
</Layout>

---
import { works } from '@/data/works';

// группируем по рядам (как .p-v3-grid-line у Лебедева). Сумма юнитов в ряду = 4.
const rowNums = [...new Set(works.map((w) => w.row))].sort((a, b) => a - b);
const rows = rowNums.map((n) => ({
  n,
  items: works.filter((w) => w.row === n),
}));

// размер → число юнитов сетки (small = 1, middle = 2). Снято замером с artlebedev.ru.
const units = (size: string) => (size === 'middle' ? 2 : 1);

// префикс под base (GitHub Pages в подпапке): пути в works.ts начинаются с '/'.
const withBase = (p: string) => import.meta.env.BASE_URL.replace(/\/$/, '') + p;
---

<section class="works" id="works">
  <div class="works__wrap">
    <div class="works__grid">
      {rows.map((row) => (
        <div class="row">
          {row.items.map((w) => (
            <a
              class="tile"
              href={withBase(`/works/${w.slug}`)}
              data-category={w.category}
              data-size={w.size}
              data-fit={w.fit ?? 'cover'}
              data-motion={w.motion}
              style={`--u:${units(w.size)}; --surface:${w.surface}`}
            >
              {w.variant === 'glow' ? (
                <div class="glow" aria-hidden="true">
                  <div class="glow__ring"></div>
                  <div class="glow__blob"></div>
                </div>
              ) : w.image ? (
                <>
                  <img class="tile__fill" src={withBase(w.image)} alt={w.title} loading="lazy" />
                  {w.layer && (
                    <img class="tile__layer" src={withBase(w.layer)} alt="" aria-hidden="true" loading="lazy" />
                  )}
                </>
              ) : null}

              <div class="tile__grad"></div>
              <div class="tile__cap">
                <p class="tile__title">{w.title}: {w.client}</p>
              </div>
            </a>
          ))}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .works { padding: var(--spacing-16) 0 var(--section-pad-y); }
  .works__wrap { width: 100%; padding: 0 15px; }

  /* ============================================================
     Сетка работ — модель artlebedev.ru (v5), снята замером в браузере.
     Ряд = flex-строка, сумма юнитов = 4. Плитка занимает --u юнитов
     по ширине (flex: --u 1 0). Высота приходит из aspect-ratio:
       small  (1 юнит) → AR 0.649  (≈2:3, портрет)
       middle (2 юнита) → AR 1.298 (≈4:3, ландшафт)
     AR пропорционален числу юнитов (--u × 0.649), поэтому ВСЕ плитки
     ряда автоматически одной высоты → ряды стыкуются без дыр.
     База 0.649 = 370/570 (1 юнит ширины / высота ряда у оригинала).
     ДИНАМИКА: сумма юнитов в ряду варьируется (3 / 4 / 5). Меньше сумма →
     шире юнит → выше ряд. Так высоты рядов разные = живой ритм, как у
     Лебедева. Контраст задаём осознанно (размер + тёплый/холодный цвет).
     ============================================================ */
  .works__grid { display: flex; flex-direction: column; gap: 8px; }
  .row { display: flex; align-items: flex-start; gap: 8px; }

  .tile {
    flex: var(--u) 1 0;
    min-width: 0;
    aspect-ratio: calc(var(--u) * 0.649);
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-card);
    background: var(--surface);
    text-decoration: none;
    color: var(--color-paper-white);
    display: block;
    /* без hover-зума / тени / подъёма — плоско и строго, как artlebedev. */
  }
  .tile__fill { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  /* contain-режим: объект по центру, surface-цвет (фон плитки) заливает поля.
     padding даёт воздух, чтобы объект не упирался в края. Низ — под зону градиента. */
  .tile[data-fit="contain"] .tile__fill {
    object-fit: contain;
    padding: 10% 10% 16%;
  }

  /* ---- Float-плитка: PNG-объект парит над surface-цветом ----
     Движение кодом (правило 7): transform-покачивание объекта + пульсирующий
     блик за ним (блик на rgba — разрешённое исключение, как glow). */
  .tile[data-motion="float"]::before {
    content: "";
    position: absolute;
    inset: -15%;
    background: radial-gradient(circle at 50% 42%,
      rgba(255, 255, 255, 0.38) 0%,
      rgba(255, 255, 255, 0.12) 38%,
      transparent 64%);
    filter: blur(28px);
    animation: float-shine 6s ease-in-out infinite;
  }
  .tile[data-motion="float"] .tile__fill {
    animation: float-bob 6s ease-in-out infinite;
    will-change: transform;
  }
  @keyframes float-bob {
    0%, 100% { transform: translateY(3%) rotate(-2deg) scale(0.97); }
    50%      { transform: translateY(-3%) rotate(2deg) scale(1.04); }
  }
  @keyframes float-shine {
    0%, 100% { opacity: 0.35; transform: scale(0.9); }
    50%      { opacity: 1;    transform: scale(1.12); }
  }
  @media (prefers-reduced-motion: reduce) {
    .tile[data-motion="float"]::before,
    .tile[data-motion="float"] .tile__fill { animation: none; }
  }

  /* ---- Rise-плитка: слой-объект (олени) появляется снизу вверх ----
     Обложка двухслойная: .tile__fill — фон, .tile__layer — прозрачный WebP
     тем же cover-кропом (файлы одного размера → совмещение 1:1).
     Скрипт взводит плитку (.rise-armed — слой уведён под нижний край) и по IO
     даёт .rise-in — слой выезжает. Без JS и при reduce-motion — статика. */
  .tile__layer { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .tile[data-motion="rise"].rise-armed .tile__layer {
    transform: translateY(103%);
    transition: none;
  }
  .tile[data-motion="rise"].rise-in .tile__layer {
    transform: translateY(0);
    transition: transform 1.1s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform;
  }
  @media (prefers-reduced-motion: reduce) {
    .tile[data-motion="rise"] .tile__layer { transform: none !important; transition: none !important; }
  }

  /* ---- Glow-плитка: синее свечение на чистом CSS (0 КБ), явное движение ----
     Разрешённое исключение из «без прозрачностей»: свечение/стекло на rgba —
     осознанно, ради эффекта. Всё на GPU, резко на любом экране, без видео. */
  .glow { position: absolute; inset: 0; background: #0a0b0d; overflow: hidden; }
  /* Светящийся обод: узкое кольцо в radial-gradient + тяжёлый blur. Пульсирует. */
  .glow__ring {
    position: absolute; top: 50%; left: 50%;
    width: 170%; aspect-ratio: 1; border-radius: 50%;
    transform: translate(-50%, -50%);
    filter: blur(22px) brightness(1.7) saturate(1.3);
    background: radial-gradient(circle,
      transparent 34%,
      rgba(96,165,250,1) 43%,
      rgba(37,99,235,1) 50%,
      rgba(37,99,235,0.75) 57%,
      transparent 66%);
    animation: glow-pulse 4s ease-in-out infinite;
  }
  /* Яркое пятно, ходит по орбите → явное непрерывное движение (сразу видно). */
  .glow__blob {
    position: absolute; top: 50%; left: 50%;
    width: 74%; aspect-ratio: 1; border-radius: 50%;
    filter: blur(26px) brightness(1.6) saturate(1.3);
    background: radial-gradient(circle,
      rgba(147,197,253,1) 0%,
      rgba(59,130,246,1) 42%,
      transparent 70%);
    animation: glow-orbit 5s linear infinite;
  }

  @keyframes glow-pulse {
    0%, 100% { opacity: .9; transform: translate(-50%, -50%) scale(.99); }
    50%      { opacity: 1;  transform: translate(-50%, -50%) scale(1.08); }
  }
  @keyframes glow-orbit {
    0%   { transform: translate(-50%, -50%) translate(0, -15%); }
    25%  { transform: translate(-50%, -50%) translate(13%, 0); }
    50%  { transform: translate(-50%, -50%) translate(0, 15%); }
    75%  { transform: translate(-50%, -50%) translate(-13%, 0); }
    100% { transform: translate(-50%, -50%) translate(0, -15%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .glow__ring, .glow__blob { animation: none; }
  }

  /* градиент снизу — картинка утопает в цвет плитки, подпись читается.
     Совпадает с оригиналом: прозрачно сверху → ~0.8 на 77% → solid у низа.
     (Исключение из «без прозрачностей» — градиент для читабельности.) */
  .tile__grad {
    position: absolute; inset: 0;
    background: linear-gradient(
      to top,
      var(--surface) 0%,                                          /* у низа — solid бренд-цвет */
      color-mix(in srgb, var(--surface) 80%, transparent) 23%,   /* разгон до 0.8 (как 77% от верха) */
      transparent 83%                                            /* плоская чистая зона сверху */
    );
  }
  .tile__cap {
    position: absolute; left: 0; right: 0; bottom: 0;
    padding: var(--spacing-16);
    display: flex; flex-direction: column; gap: 2px;
  }
  /* Подпись — ОДНОЙ строкой, единым кеглем: «Название: описание».
     Раздельные title/meta разных размеров отклонены — читается как единая мысль. */
  .tile__title { margin: 0; font-size: var(--text-lead); font-weight: var(--fw-medium); line-height: 1.2; }

  /* ---- Адаптив ---- */
  /* Планшет: те же ряды, AR работает сам (высота тянется от ширины). */
  @media (max-width: 1079px) {
    .works__grid { gap: 6px; }
    .row { gap: 6px; }
  }
  /* Мобайл/узкий планшет — модель artlebedev: middle во всю ширину, small по 2 в ряд.
     .row → display:contents: плитки текут в ОБЩИЙ 2-колоночный грид сплошным
     потоком (small'ы парятся даже между исходными рядами). row dense убирает
     дыры от одиночных small. middle спанит 2 колонки.
     ВАЖНО: flex-свойства в гриде игнорируются — высоту задаёт aspect-ratio. */
  @media (max-width: 767px) {
    .works__grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-auto-flow: row dense;
      gap: 6px;
    }
    .row { display: contents; }
    .tile { width: auto; aspect-ratio: 0.66; }                /* small: портрет, 1 колонка */
    .tile[data-size="middle"] { grid-column: span 2; aspect-ratio: 1.5; } /* middle: ландшафт во всю ширину */
    .tile__title { font-size: var(--text-body); }
  }
</style>

<script>
  // Rise-плитки: слой выезжает снизу, когда плитка входит в вьюпорт.
  // Взводим только при живом JS + IO + без reduce-motion — иначе статика.
  function initRise() {
    const tiles = document.querySelectorAll<HTMLElement>('.tile[data-motion="rise"]');
    if (!tiles.length || !('IntersectionObserver' in window)) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (!e.isIntersecting) continue;
          e.target.classList.add('rise-in');
          io.unobserve(e.target);
        }
      },
      { threshold: 0.3 },
    );
    tiles.forEach((t) => {
      if (t.classList.contains('rise-armed') || t.classList.contains('rise-in')) return;
      t.classList.add('rise-armed');
      io.observe(t);
    });
  }
  initRise();
  document.addEventListener('astro:page-load', initRise);
</script>

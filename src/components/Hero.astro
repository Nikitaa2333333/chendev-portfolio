---
// Реальный hero — первый драфт. Редактируй текст прямо тут.
---

<section class="hero" id="hero">
  <div class="container">
    <h1 class="hero__title">
      Я — Никита Чендев. Создаю потрясающие сайты
      для малого и среднего бизнеса
    </h1>

    <p class="hero__lead">
      Делаю сайты с нуля, без шаблона и конструктора.
      Вы получите сайт с уникальным дизайном за две недели.
    </p>
  </div>
</section>

<style>
  .hero {
    padding: var(--section-pad-y) 0 var(--spacing-16);
    background: var(--color-paper-white);
    color: var(--color-ink-black);
    text-align: center;
  }
  .hero__title { color: var(--color-ink-black); }
  .hero__lead { color: var(--color-ink-black); }
  .hero__title {
    font-size: var(--text-h1);
    line-height: 0.9;
    letter-spacing: var(--tr-h1);
    font-weight: var(--fw-black);
    margin: 0 auto var(--spacing-32);
    max-width: 18ch;
  }
  .hero__mark {
    color: var(--color-ink-black);
  }
  .hero__lead {
    font-size: var(--text-lead);
    line-height: var(--lh-lead);
    letter-spacing: var(--tr-lead);
    font-weight: var(--fw-medium);
    max-width: 52ch;
    margin: 0 auto;
  }

  @media (max-width: 719px) {
    .hero__title { font-size: clamp(30px, 8.5vw, 44px); max-width: none; }
  }
</style>

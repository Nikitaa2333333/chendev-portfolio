---
// Hero: фото/видео автора во всю ширину. Десктоп: ТЕКСТ ЛЕЖИТ НА ВИДЕО
// (заголовок слева, лид+контакты справа), белым, поверх тёмного градиента.
// Мобилка ≤719px: текст ПОД видео, отдельным блоком на белом, чёрным.
// Вариант GIF (video.mp4 → сжат в public/hero.mp4). Постер — public/hero-poster.webp.
const withBase = (p: string) => import.meta.env.BASE_URL.replace(/\/$/, '') + p;
---

<section class="hero" id="hero">
  <div class="hero__media">
    <!-- Статичный кадр — всегда под видео. Если браузер блокирует автоплей
         (iOS Low Power и т.п.), прячем видео и остаётся он — без мёртвой кнопки play. -->
    <img class="hero__asset hero__poster" src={withBase('/hero-poster.webp')} alt="Никита Чендев" />
    <video
      class="hero__asset hero__video"
      data-hero-video
      muted
      loop
      playsinline
      webkit-playsinline
      autoplay
      preload="auto"
      poster={withBase('/hero-poster.webp')}
    >
      <source src={withBase('/hero.mp4')} type="video/mp4" />
    </video>
    <div class="hero__fade"></div>
  </div>

  <div class="hero__body container">
    <div class="hero__main">
      <span class="hero__eyebrow">Я — Никита Чендев</span>

      <h1 class="hero__title">
        Создаю потрясающие сайты для малого и среднего бизнеса
      </h1>
    </div>

    <div class="hero__side">
      <p class="hero__lead">
        Делаю сайты с нуля, без шаблона и конструктора. Вы получаете сайт
        с уникальным дизайном за две недели и бесплатной гарантией один год.
      </p>
      <div class="hero__links">
        <a href="https://t.me/chendev1" target="_blank" rel="noopener noreferrer">Telegram</a>
        <a href="mailto:chendev.nik@gmail.com">Почта</a>
        <a href="tel:+79531216477">+7 953 121 64 77</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative; /* якорь для absolute-текста на десктопе */
    background: var(--color-paper-white);
    color: var(--color-ink-black);
  }
  /* Медиа во всю ширину, соотношение 16:9 (меньше обрезки, чем узкая полоса).
     Потолок по высоте — чтобы на коротких экранах не улетало. */
  .hero__media {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    max-height: 86vh;
    overflow: hidden;
  }
  .hero__asset {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }
  .hero__poster { z-index: 0; }   /* статичный кадр под видео */
  .hero__video { z-index: 1; }    /* видео поверх; прячется, если автоплей заблокирован */
  .hero__video[hidden] { display: none; }
  /* Тёмный градиент снизу — текст читается на любом кадре (тот же рецепт,
     что на hero кейсов; разрешённое исключение из «без прозрачностей»). */
  .hero__fade {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 75%;
    z-index: 2;   /* поверх видео (video z-index:1), иначе градиент перекрывается */
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.6) 0%,
      rgba(0, 0, 0, 0.15) 45%,
      transparent 70%
    );
  }
  /* Текст ЛЕЖИТ НА ВИДЕО: заголовок внизу слева, лид — внизу справа.
     Разнесены по углам, чтобы не накрывать лицо в центре кадра. */
  .hero__body {
    position: absolute;
    left: 0;
    right: 0;
    bottom: var(--spacing-32);
    z-index: 3;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--spacing-48);
    text-align: left;
  }
  /* Имя — бирка-эйброу, прижата к заголовку (зазор в em — едет с кеглем). */
  .hero__eyebrow {
    display: block;
    font-size: clamp(18px, 4.6vw, 34px);
    font-weight: var(--fw-black);
    color: var(--color-paper-white);
    margin-bottom: 0.2em;
  }
  /* Заголовок — токен h2 (уменьшен с гигантского clamp, чтобы не накрывал
     кадр), Inter 900, без строк-сирот. */
  .hero__title {
    font-size: var(--text-h2);
    line-height: 1.05;
    letter-spacing: var(--tr-h2);
    font-weight: var(--fw-black);
    color: var(--color-paper-white);
    text-wrap: balance;
    margin: 0;
    max-width: 22ch;
  }
  /* Правая колонка: лид + строка гиперссылок-контактов.
     Ширина — доля ряда (не ch): модуль упирается в правое поле,
     текст и ссылки заполняют его целиком. */
  .hero__side {
    flex: 0 1 36%;
    min-width: 320px;
  }
  .hero__lead {
    font-size: var(--text-lead);
    line-height: 1.2;
    letter-spacing: var(--tr-lead);
    font-weight: var(--fw-medium);
    color: var(--color-paper-white);
    margin: 0 0 0.8em;
  }
  /* Контакты — стандарт текстовой ссылки: белые, линия sky-tint, на ховере белеет. */
  .hero__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-16);
  }
  .hero__links a {
    font-size: var(--text-lead);
    font-weight: var(--fw-medium);
    /* Номер не разрывается посреди цифр: группы «953 121 64 77» должны
       остаться одной строкой, переносится только сама ссылка целиком. */
    white-space: nowrap;
    color: var(--color-paper-white);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.2em;
    text-decoration-skip-ink: none;
    text-decoration-color: var(--color-sky-tint);
  }
  .hero__links a:hover { text-decoration-color: var(--color-paper-white); }

  /* ── Мобилка: текст НЕ на видео (перекрывал человека в кадре), а ПОД ним,
     на белом, чёрным (правило: на белом — чёрный). Низ видео растворяется
     БЕЛЫМ градиентом (как градиент на hero кейсов, но в цвет канвы), текст
     чуть заходит на растворённую зону — стык блоков плавный, без резкой линии. ── */
  @media (max-width: 719px) {
    .hero__fade {
      height: 45%;
      background: linear-gradient(to bottom, transparent, var(--color-paper-white));
    }
    .hero__body {
      position: relative; /* поверх растворённого низа видео */
      z-index: 3;
      flex-direction: column;
      align-items: flex-start;
      gap: var(--spacing-16);
      margin-top: -10vw; /* заход на видео ∝ ширине экрана (высота видео тоже ∝) */
      padding-bottom: var(--spacing-8);
    }
    .hero__eyebrow,
    .hero__title,
    .hero__lead { color: var(--color-ink-black); }
    .hero__side { flex: none; width: 100%; min-width: 0; }
    /* Ссылки на белом — чёрные, линия blue-gray-mist (стандарт для белого фона) */
    .hero__links a {
      color: var(--color-ink-black);
      text-decoration-color: var(--color-blue-gray-mist);
    }
    .hero__links a:hover { text-decoration-color: var(--color-ink-black); }
  }
</style>

<script>
  // Hero-видео: играет в зоне видимости, пауза вне (экономит батарею).
  // Если браузер блокирует автоплей (iOS Low Power и т.п.) → прячем видео,
  // остаётся статичный постер (без мёртвой системной кнопки play).
  // prefers-reduced-motion → тоже остаётся постер.
  function initHeroVideo() {
    const v = document.querySelector<HTMLVideoElement>('[data-hero-video]');
    if (!v) return;
    const fallbackToPoster = () => { v.hidden = true; v.pause(); };
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce) { fallbackToPoster(); return; }
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          const p = v.play();
          if (p && typeof p.catch === 'function') p.catch(fallbackToPoster);
        } else {
          v.pause();
        }
      }
    }, { threshold: 0.15 });
    io.observe(v);
  }
  initHeroVideo();
  document.addEventListener('astro:page-load', initHeroVideo);
</script>

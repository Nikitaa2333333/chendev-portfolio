---
// Hero: фото/видео автора во всю ширину, ТЕКСТ ЛЕЖИТ НА ВИДЕО — внизу слева,
// белым, поверх тёмного градиента (как на hero страниц кейсов).
// Вариант GIF (video.mp4 → сжат в public/hero.mp4). Постер — public/hero-poster.webp.
const withBase = (p: string) => import.meta.env.BASE_URL.replace(/\/$/, '') + p;
---

<section class="hero" id="hero">
  <div class="hero__media">
    <!-- Статичный кадр — всегда под видео. Если браузер блокирует автоплей
         (iOS Low Power и т.п.), прячем видео и остаётся он — без мёртвой кнопки play. -->
    <img class="hero__asset hero__poster" src={withBase('/hero-poster.webp')} alt="Никита Чендев" />
    <video
      class="hero__asset hero__video"
      data-hero-video
      muted
      loop
      playsinline
      webkit-playsinline
      autoplay
      preload="auto"
      poster={withBase('/hero-poster.webp')}
    >
      <source src={withBase('/hero.mp4')} type="video/mp4" />
    </video>
    <div class="hero__fade"></div>

    <div class="hero__body container">
      <span class="hero__eyebrow">Я — Никита Чендев</span>

      <h1 class="hero__title">
        Создаю потрясающие сайты для малого и среднего бизнеса
      </h1>

      <p class="hero__lead">
        Делаю сайты с нуля, без шаблона и конструктора. Вы получаете сайт
        с уникальным дизайном за две недели и бесплатной гарантией один год.
      </p>
    </div>
  </div>
</section>

<style>
  .hero {
    background: var(--color-paper-white);
    color: var(--color-ink-black);
  }
  /* Медиа во всю ширину, соотношение 16:9 (меньше обрезки, чем узкая полоса).
     Потолок по высоте — чтобы на коротких экранах не улетало. */
  .hero__media {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    max-height: 86vh;
    overflow: hidden;
  }
  .hero__asset {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }
  .hero__poster { z-index: 0; }   /* статичный кадр под видео */
  .hero__video { z-index: 1; }    /* видео поверх; прячется, если автоплей заблокирован */
  .hero__video[hidden] { display: none; }
  /* Тёмный градиент снизу — текст читается на любом кадре (тот же рецепт,
     что на hero кейсов; разрешённое исключение из «без прозрачностей»). */
  .hero__fade {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 75%;
    z-index: 2;   /* поверх видео (video z-index:1), иначе градиент перекрывается */
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.6) 0%,
      rgba(0, 0, 0, 0.15) 45%,
      transparent 70%
    );
  }
  /* Текст ЛЕЖИТ НА ВИДЕО: внизу слева, белым, по левому краю. */
  .hero__body {
    position: absolute;
    left: 0;
    right: 0;
    bottom: var(--spacing-32);
    z-index: 3;
    text-align: left;
  }
  /* Имя — бирка-эйброу над крупным заголовком. */
  .hero__eyebrow {
    display: block;
    font-size: clamp(18px, 4.6vw, 34px);
    font-weight: var(--fw-black);
    color: var(--color-paper-white);
    margin-bottom: var(--spacing-12);
  }
  /* Крупный заголовок — Inter 900, без строк-сирот. */
  .hero__title {
    font-size: clamp(34px, 8.8vw, 76px);
    line-height: 1.03;
    letter-spacing: var(--tr-h1);
    font-weight: var(--fw-black);
    color: var(--color-paper-white);
    text-wrap: balance;
    margin: 0 0 var(--spacing-24);
    max-width: 22ch;
  }
  /* Лид — белый на видео, межстрочный 120%. */
  .hero__lead {
    font-size: var(--text-lead);
    line-height: 1.2;
    letter-spacing: var(--tr-lead);
    font-weight: var(--fw-medium);
    color: var(--color-paper-white);
    max-width: 52ch;
    margin: 0;
  }

  /* Мобилка: 16:9 слишком низкий для наложенного текста — медиа растёт
     в высоту (кадрируется cover'ом), текст помещается на нём. */
  @media (max-width: 719px) {
    .hero__media { aspect-ratio: auto; height: 78svh; }
    .hero__body { bottom: var(--spacing-24); }
  }
</style>

<script>
  // Hero-видео: играет в зоне видимости, пауза вне (экономит батарею).
  // Если браузер блокирует автоплей (iOS Low Power и т.п.) → прячем видео,
  // остаётся статичный постер (без мёртвой системной кнопки play).
  // prefers-reduced-motion → тоже остаётся постер.
  function initHeroVideo() {
    const v = document.querySelector<HTMLVideoElement>('[data-hero-video]');
    if (!v) return;
    const fallbackToPoster = () => { v.hidden = true; v.pause(); };
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce) { fallbackToPoster(); return; }
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          const p = v.play();
          if (p && typeof p.catch === 'function') p.catch(fallbackToPoster);
        } else {
          v.pause();
        }
      }
    }, { threshold: 0.15 });
    io.observe(v);
  }
  initHeroVideo();
  document.addEventListener('astro:page-load', initHeroVideo);
</script>

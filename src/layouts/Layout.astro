---
// Self-hosted Inter (500 + 900) — без render-blocking коннектов к Google Fonts.
// Astro бандлит CSS same-origin, woff2 грузятся локально → быстрый FCP/LCP.
import '@fontsource/inter/500.css';
import '@fontsource/inter/900.css';
import '@/styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;   // путь от корня public ('/works/….webp') — превью ссылки в соцсетях/мессенджерах
  ogType?: string;    // 'website' (дефолт) | 'article' для кейсов
  noindex?: boolean;  // служебные страницы (/ds) — не в выдачу
  schema?: object;    // JSON-LD микроразметка страницы (schema.org)
}

const {
  title = 'Никита Чендев — дизайн и разработка сайтов',
  description = 'Делаю сайты с нуля, без шаблона и конструктора: уникальный дизайн за две недели и бесплатная гарантия один год. Портфолио — 13 живых проектов.',
  ogImage = '/hero-poster.webp',
  ogType = 'website',
  noindex = false,
  schema,
} = Astro.props;

// Абсолютные URL под GitHub Pages в подпапке (site + base из astro.config).
const withBase = (p: string) => import.meta.env.BASE_URL.replace(/\/$/, '') + p;
const abs = (p: string) => new URL(withBase(p), Astro.site).href;
// canonical — всегда со слэшем на конце (GH Pages отдаёт каталоги со слэшем).
const canonical = new URL(
  Astro.url.pathname.endsWith('/') ? Astro.url.pathname : Astro.url.pathname + '/',
  Astro.site,
).href;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />

    {/* Подтверждение прав в Google Search Console. НЕ УДАЛЯТЬ — Google
        перепроверяет тег, без него права слетят. Права в Яндекс.Вебмастере
        держит файл public/yandex_59714c75498b0267.html — его тоже не трогать. */}
    <meta name="google-site-verification" content="zdsVOzOPQYukg6iFgMxBSXA6wpm8E3wRPNMq6kYuBfs" />

    <title>{title}</title>

    {/* Open Graph + Twitter Card — превью ссылки в Telegram/WhatsApp/соцсетях */}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Никита Чендев" />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={abs(ogImage)} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={abs(ogImage)} />

    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}

    {/* Яндекс.Метрика (счётчик 110838314). is:inline — код из панели, Astro не бандлит.
        ClientRouter делает SPA-переходы без перезагрузки → страницы после первой
        докидываем в Метрику руками: hit на astro:after-swap (на initial load не
        срабатывает — его считает init, двойного учёта нет). */}
    <script is:inline>
      (function(m,e,t,r,i,k,a){
          m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
          m[i].l=1*new Date();
          for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
          k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)
      })(window, document,'script','https://mc.yandex.ru/metrika/tag.js?id=110838314', 'ym');

      ym(110838314, 'init', {ssr:true, webvisor:true, clickmap:true, ecommerce:"dataLayer", referrer: document.referrer, url: location.href, accurateTrackBounce:true, trackLinks:true});

      document.addEventListener('astro:after-swap', function () {
        ym(110838314, 'hit', location.href);
      });
    </script>
    <noscript><div><img src="https://mc.yandex.ru/watch/110838314" style="position:absolute; left:-9999px;" alt="" /></div></noscript>

    <ClientRouter />
  </head>
  <body>
    <slot />

    {/* Кнопка заказа — на всех страницах, кроме самой формы (там она бы вела
        на страницу, где человек уже стоит). Ведёт на /order/, не модалка. */}
    {!Astro.url.pathname.startsWith(withBase('/order')) && (
      <a class="order-cta" href={withBase('/order/')}>Заказать сайт</a>
    )}
  </body>
</html>

<script>
  // ── Глобальный типограф: убирает висячие предлоги/союзы ВЕЗДЕ ──
  // Проходит по всем текстовым узлам страницы и клеит короткие слова
  // неразрывным пробелом. Работает сам — ничего оборачивать в шаблонах не надо.
  import { typo } from '@/lib/typo';

  function fixTypography(root: HTMLElement | null = document.body) {
    if (!root) return;
    const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, {
      acceptNode(node) {
        const tag = node.parentElement?.tagName;
        if (tag === 'SCRIPT' || tag === 'STYLE' || tag === 'TEXTAREA' || tag === 'CODE' || tag === 'PRE')
          return NodeFilter.FILTER_REJECT;
        return node.nodeValue && node.nodeValue.trim()
          ? NodeFilter.FILTER_ACCEPT
          : NodeFilter.FILTER_REJECT;
      },
    });
    const nodes: Text[] = [];
    let n: Node | null;
    while ((n = walker.nextNode())) nodes.push(n as Text);
    for (const t of nodes) {
      const fixed = typo(t.nodeValue ?? '');
      if (fixed !== t.nodeValue) t.nodeValue = fixed;
    }
  }

  fixTypography();
  document.addEventListener('astro:page-load', () => fixTypography());
</script>

<style>
  /* ── Плавающая кнопка «Заказать сайт» ──
     Fixed снизу справа, живёт на всех страницах и не уезжает при скролле.
     Сплошной акцент без теней и прозрачностей (правило 2). Кнопка «← к работам»
     на кейсах прижата к ЛЕВОМУ верхнему углу — не пересекаются.
     Форма прямоугольная с --radius-card (4px), как плитки работ: от пилюль
     в интерфейсе уходим, скругление одно на весь сайт. */
  .order-cta {
    position: fixed;
    right: 15px;
    /* safe-area — чтобы на айфонах не залезала под системную полоску */
    bottom: calc(15px + env(safe-area-inset-bottom, 0px));
    z-index: 60;
    padding: 14px 26px;
    font-size: var(--text-body);
    font-weight: var(--fw-medium);
    line-height: 1;
    color: var(--color-paper-white);
    background: var(--color-accent);
    border-radius: var(--radius-card);
    text-decoration: none;
    white-space: nowrap;
  }
  .order-cta:hover { background: var(--color-accent-700); }
</style>

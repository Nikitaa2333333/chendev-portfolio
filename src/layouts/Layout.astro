---
// Self-hosted Inter (500 + 900) — без render-blocking коннектов к Google Fonts.
// Astro бандлит CSS same-origin, woff2 грузятся локально → быстрый FCP/LCP.
import '@fontsource/inter/500.css';
import '@fontsource/inter/900.css';
import '@/styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Портфолио — скелет',
  description = 'Структурный скелет портфолио. Контент и визуальный стиль наполняются итеративно.',
} = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/favicon.svg`} />

    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <slot />
  </body>
</html>

<script>
  // ── Глобальный типограф: убирает висячие предлоги/союзы ВЕЗДЕ ──
  // Проходит по всем текстовым узлам страницы и клеит короткие слова
  // неразрывным пробелом. Работает сам — ничего оборачивать в шаблонах не надо.
  import { typo } from '@/lib/typo';

  function fixTypography(root: HTMLElement | null = document.body) {
    if (!root) return;
    const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, {
      acceptNode(node) {
        const tag = node.parentElement?.tagName;
        if (tag === 'SCRIPT' || tag === 'STYLE' || tag === 'TEXTAREA' || tag === 'CODE' || tag === 'PRE')
          return NodeFilter.FILTER_REJECT;
        return node.nodeValue && node.nodeValue.trim()
          ? NodeFilter.FILTER_ACCEPT
          : NodeFilter.FILTER_REJECT;
      },
    });
    const nodes: Text[] = [];
    let n: Node | null;
    while ((n = walker.nextNode())) nodes.push(n as Text);
    for (const t of nodes) {
      const fixed = typo(t.nodeValue ?? '');
      if (fixed !== t.nodeValue) t.nodeValue = fixed;
    }
  }

  fixTypography();
  document.addEventListener('astro:page-load', () => fixTypography());
</script>
